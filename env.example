# ───────────────────────────────────────────────────────
# Forge — environment variables example.
# Copy to `.env.local` and fill in. Never commit secrets.
# ───────────────────────────────────────────────────────

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin — one of:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# or inline JSON (escape newlines in private_key):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google OAuth + Calendar
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_WEBHOOK_URL=https://your-public-host/api/integrations/google/webhook

# Notion OAuth — create a public integration at
# https://www.notion.so/my-integrations, set the redirect URI to
# <YOUR_HOST>/api/integrations/notion/callback, and copy the OAuth
# client id + secret here. Leave blank to hide the Notion Connect
# panel entirely.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/notion/callback

# Auth fallback — when "true", requireUser falls back to a local
# JWT-payload decode (still verifying iss/aud/exp) if the Admin SDK
# can't verify the signature. Defaults to "true" in dev, "false" in
# production. Set to "false" in dev to force strict mode.
FORGE_AUTH_FALLBACK=

# Crypto — generate with `openssl rand -base64 32`
SERVER_ENCRYPTION_KEY=
OAUTH_STATE_SECRET=

# Cron
CRON_SECRET=
GCAL_SYNC_CONCURRENCY=5

# Groq — primary AI provider for chat, writing assist, claim
# extraction, and semantic contradiction detection. Get a free key at
# https://console.groq.com (free tier: 30 req/min, ~14.4k req/day for
# llama-3.3-70b-versatile).
GROQ_API_KEY=
# Optional override — defaults to llama-3.3-70b-versatile.
GROQ_MODEL=

# Exa — research search backend for /research.
EXA_API_KEY=

# Sentry — leave blank to disable observability silently.
# Get a DSN at https://sentry.io (free tier is fine for dev).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=

# Playwright E2E — set when running against an emulated Firebase backend.
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_E2E_USER_EMAIL=e2e@forge.test
PLAYWRIGHT_E2E_USER_PASSWORD=playwright-secret-not-real
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost:8080
NEXT_PUBLIC_AUTH_EMULATOR_HOST=http://localhost:9099
