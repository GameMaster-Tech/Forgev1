{
  "indexes": [
    {
      "_comment": "Projects — owner's project list (most-recent first).",
      "collectionGroup": "projects",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },

    {
      "_comment": "Documents — list per project.",
      "collectionGroup": "documents",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Documents — owner's docs across all projects.",
      "collectionGroup": "documents",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },

    {
      "_comment": "Sync — Assertion latest-value resolver.",
      "collectionGroup": "assertions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "key", "order": "ASCENDING" },
        { "fieldPath": "sourcedAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Sync — Constraints detector ordering (severity DESC effectively via ordering).",
      "collectionGroup": "constraints",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "severity", "order": "ASCENDING" },
        { "fieldPath": "kind", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Lattice — children of a parent task.",
      "collectionGroup": "subtasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "parentId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "Tempo / Calendar — events sorted for the grid + status filter.",
      "collectionGroup": "events",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "start", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "Tempo — GCal remote→local lookup.",
      "collectionGroup": "events",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "externalId", "order": "ASCENDING" },
        { "fieldPath": "externalSource", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "Tempo — task priority queue ordered by due date.",
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "due", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "Tempo — tasks bound to a goal (goal-gravity calculation).",
      "collectionGroup": "tasks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "boundGoalId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Notifications — unread bell badge query.",
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "read", "order": "ASCENDING" },
        { "fieldPath": "at", "order": "DESCENDING" }
      ]
    },

    {
      "_comment": "Activity feed — filter by source + chronological.",
      "collectionGroup": "activity",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "source", "order": "ASCENDING" },
        { "fieldPath": "at", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Versions — filter by source + chronological.",
      "collectionGroup": "versions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "source", "order": "ASCENDING" },
        { "fieldPath": "at", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Sharing — list grants on a resource.",
      "collectionGroup": "shares",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "resource.kind", "order": "ASCENDING" },
        { "fieldPath": "resource.id", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Collab — Yjs update prune by age (compact() job).",
      "collectionGroup": "updates",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "at", "order": "ASCENDING" },
        { "fieldPath": "peerId", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Pulse — refactor rejection cooldown lookup.",
      "collectionGroup": "rejections",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "blockId", "order": "ASCENDING" },
        { "fieldPath": "expiresAt", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Veritas — claim listing (Phase 1).",
      "collectionGroup": "veritasClaims",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "retired", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasClaims",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasClaims",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "canonicalHash", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasClaims",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "topicId", "order": "ASCENDING" },
        { "fieldPath": "retired", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasClaims",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "retired", "order": "ASCENDING" },
        { "fieldPath": "entities", "arrayConfig": "CONTAINS" }
      ]
    },
    {
      "_comment": "Veritas — retire-cascade lookup.",
      "collectionGroup": "veritasClaims",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "derivation.parentClaimIds", "arrayConfig": "CONTAINS" }
      ]
    },

    {
      "_comment": "Veritas — links by source claim.",
      "collectionGroup": "veritasClaimLinks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "from", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "Veritas — links by target claim.",
      "collectionGroup": "veritasClaimLinks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "to", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Veritas — contradictions listing.",
      "collectionGroup": "veritasContradictions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "detectedAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasContradictions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "detectedAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasContradictions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "a", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasContradictions",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "b", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Forge Reactive Workspace — graph snapshots per project (newest first). Filter on ownerId is required by the security rules so the rule can verify ownership before returning rows.",
      "collectionGroup": "forge_graph_snapshots",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "ownerId", "order": "ASCENDING" },
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Forge Reactive Workspace — tempo run history per project.",
      "collectionGroup": "forge_tempo_runs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "ownerId", "order": "ASCENDING" },
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "Forge Reactive Workspace — saved invariants per project.",
      "collectionGroup": "forge_invariants",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "ownerId", "order": "ASCENDING" },
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "updatedAt", "order": "DESCENDING" }
      ]
    },

    {
      "_comment": "Echo — active notices per user, ordered most-recent first. The client filters snoozed records in-memory after this query. Path is a subcollection so this index applies at the collection-group level too.",
      "collectionGroup": "echo_notices",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "dismissedAt", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },

    {
      "_comment": "Veritas — episodes chronological.",
      "collectionGroup": "veritasEpisodes",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasEpisodes",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasEpisodes",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "type", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "veritasEpisodes",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "claimsReferenced", "arrayConfig": "CONTAINS" }
      ]
    },
    {
      "collectionGroup": "veritasEpisodes",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "claimsCreated", "arrayConfig": "CONTAINS" }
      ]
    },
    {
      "collectionGroup": "veritasEpisodes",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "projectId", "order": "ASCENDING" },
        { "fieldPath": "claimsRetired", "arrayConfig": "CONTAINS" }
      ]
    }
  ],
  "_fieldOverridesNote": "TTL field overrides for `events.ttlExpiresAt` and `rejections.expiresAt` require billing-enabled Firestore. Re-enable when the project switches to Blaze plan: see git history of this file for the original entries.",
  "fieldOverrides": []
}
