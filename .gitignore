# ───────────────────────────────────────────────────────
# Forge .gitignore
# ───────────────────────────────────────────────────────

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Build outputs
/.next/
/out/
/build
/dist
*.tsbuildinfo

# Type generation
next-env.d.ts

# Env files — never commit secrets
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example
!.env.sample

# Cloud / deploy
.vercel
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc
*.pem
*.key
*.cert
*.crt

# Claude Code worktree scaffolding — keep the worktree files out of
# commits, but DO track docs and skill artifacts under .claude/ itself.
.claude/worktrees/
.claude/launch.json
.claude/settings.local.json

# Python (training / kaggle)
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints
*.ipynb_checkpoints/

# Training artifacts (large)
veritas/training/checkpoints/
veritas/training/runs/
veritas/training/.cache/
kaggle/notebooks/_outputs/
