rules_version = '2';

// Firebase Storage rules for Forge editor uploads.
//
// Uploads are written under `user-uploads/{userId}/{docId}/{file}` by the
// signed-in owner (see src/lib/firebase/storage.ts). Only that user may
// write; reads are allowed for any signed-in user so shared documents can
// render embedded images. Size + content-type are constrained on write.
service firebase.storage {
  match /b/{bucket}/o {
    match /user-uploads/{userId}/{docId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Everything else is denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
